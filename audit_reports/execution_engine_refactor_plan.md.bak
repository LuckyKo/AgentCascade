    instance_name, agent_class, error = self._validate_call_agent_args(...)
    if error:
        return error
    
    # Check nesting depth
    depth_error = self._check_nesting_depth(...)
    if depth_error:
        return depth_error
    
    # Check slot collision
    caller_holds_slot = ...
    
    if caller_holds_slot:
        return self._run_child_sync(...)
    else:
        return self._run_child_async(...)
```

